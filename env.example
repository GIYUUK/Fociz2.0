# Copier ce fichier en ".env" (même dossier que docker-compose.yml) et remplir.

# Clé API Resend (gratuite) : https://resend.com -> Onboarding -> API Keys
RESEND_API_KEY=

# Adresse d'expéditeur. Pour tester sans domaine à soi, garder onboarding@resend.dev
# (fonctionne tout de suite mais atterrit parfois en spam).
# Pour un vrai envoi fiable : vérifier son propre domaine dans Resend,
# puis mettre par ex. MAIL_FROM=Fociz <bonjour@fociz.fr>
MAIL_FROM=Fociz <onboarding@resend.dev>

# Adresse du SITE (pas du serveur), utilisée dans le lien envoyé par email.
# Exemple : https://fociz.netlify.app
FRONT_URL=

# Clé pour accéder à /admin (liste des comptes créés). Vide = page désactivée.
# Choisir une chaîne longue et aléatoire, à garder secrète.
ADMIN_KEY=
